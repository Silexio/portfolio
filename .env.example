# ── Base ──────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://silexio.be"

# ── Base de données (Supabase Postgres) ───────────────────────
# Sur Vercel, l'intégration Supabase injecte POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING ;
# le code les utilise en repli, donc ces deux variables sont surtout pour le dev local.
# Runtime : connexion POOLÉE (PgBouncer, port 6543).
DATABASE_URL="postgresql://URL"
# Introspection Prisma (db pull) : connexion DIRECTE (port 5432).
DIRECT_URL="postgresql://URL_DIRECT"

# ── Cloudflare Turnstile (anti-bot) ───────────────────────────
# Clés de test Cloudflare (toujours valides) pour le dev :
#   site:  1x00000000000000000000AA  · secret: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ── SMTP (Nodemailer) — notifications de réservation ──────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="no-reply@silexio.be"
SMTP_PASS="changeme"
SMTP_FROM="Silexio <no-reply@silexio.be>"
# Destinataire des demandes de RDV (propriétaire).
BOOKING_NOTIFY_EMAIL="contact@silexio.be"

# ── Secrets (générer : openssl rand -hex 32) ──────────────────
# Signe les liens confirmer/refuser des emails.
BOOKING_ACTION_SECRET="change-me-32-bytes-hex"
# Hash des IP pour le rate limit (RGPD : jamais d'IP en clair).
IP_HASH_SECRET="change-me-32-bytes-hex"
